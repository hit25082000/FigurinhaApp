datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Lead {
  id          String   @id @default(cuid())
  name        String
  email       String
  birthDate   DateTime?
  club        String?
  weightKg    Int?
  heightCm    Int?
  photoUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orders      Order[]
}

model Order {
  id              String   @id @default(cuid())
  leadId          String
  lead            Lead     @relation(fields: [leadId], references: [id])
  status          String
  stickerUrl      String?
  stickerPdfUrl   String?
  paymentStatus   String?
  paymentProvider String?
  paymentId       String?
  checkoutUrl     String?
  totalCents      Int      @default(1290)
  selectedBumps   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  priceCents  Int
  type        String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model PaymentEvent {
  id          String   @id @default(cuid())
  orderId     String?
  provider    String
  eventType   String
  rawPayload   String
  createdAt   DateTime @default(now())
}
